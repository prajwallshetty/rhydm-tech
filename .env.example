# Copy to .env and fill in. Never commit the real .env.

# Postgres connection string.
# Local development: run `npx prisma dev` and paste the URL it prints.
# Production: use your hosted Postgres (Neon, Supabase, RDS, ...).
DATABASE_URL="postgresql://user:password@localhost:5432/rhydm?schema=public"

# Only needed for `prisma migrate dev`, which creates a temporary shadow
# database to detect schema drift. Not required in production.
SHADOW_DATABASE_URL=""

# Public origin, used for canonical URLs, sitemap.xml, robots.txt and OG tags.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Cloudinary media library (admin uploads). Create a free account at
# cloudinary.com → Dashboard shows all three values. Uploads are signed
# server-side; the secret is never sent to the browser.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
